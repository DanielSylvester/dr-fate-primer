{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dr-fate.dev/schemas/memory.json",
  "title": "Memory",
  "description": "A unit of knowledge stored in dr-fate-memory",
  "type": "object",
  "required": ["id", "source", "type", "content", "created_at"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "source": { "type": "string", "description": "Origin service (e.g., 'orchestrator', 'cli', 'ingest')" },
    "type": {
      "type": "string",
      "enum": ["document", "decision", "outcome", "feedback", "learning", "synthesis", "code", "note"]
    },
    "content": { "type": "string", "minLength": 1, "description": "Raw text content" },
    "embedding": {
      "type": "array",
      "items": { "type": "number" },
      "description": "Dense vector representation (768-dim for bge-base-en-v1.5)"
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value pairs. Account_id SHOULD be present."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable labels (e.g., ['smartworks-india', 'google-ads'])"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time", "description": "Optional TTL" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "For synthesized memories" }
  }
}
