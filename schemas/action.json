{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dr-fate.dev/schemas/action.json",
  "title": "Action",
  "description": "A decision that has been processed",
  "type": "object",
  "required": ["id", "decision_id", "status"],
  "properties": {
    "id": { "type": "string" },
    "decision_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "validated", "executed", "failed", "rejected", "skipped"]
    },
    "proposed_at": { "type": "string", "format": "date-time" },
    "executed_at": { "type": "string", "format": "date-time" },
    "mutation_id": { "type": "string" },
    "error": { "type": ["string", "null"] }
  }
}
