{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dr-fate.dev/schemas/safety.json",
  "title": "SafetyResult",
  "description": "Result of a single safety gate check",
  "type": "object",
  "required": ["name", "passed"],
  "properties": {
    "name": { "type": "string" },
    "passed": { "type": "boolean" },
    "reason": { "type": "string" },
    "severity": { "type": "string", "enum": ["info", "warning", "block"] }
  }
}
