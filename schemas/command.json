{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dr-fate.dev/schemas/command.json",
  "title": "Command",
  "description": "An executable command sent to dr-fate-executor",
  "type": "object",
  "required": ["id", "source", "tool", "args"],
  "properties": {
    "id": { "type": "string" },
    "source": { "type": "string", "enum": ["orchestrator", "cli", "mcp"] },
    "tool": { "type": "string" },
    "args": { "type": "object" },
    "dry_run": { "type": "boolean", "default": true },
    "account_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "validated_at": { "type": "string", "format": "date-time" },
    "validation_result": {
      "type": "object",
      "properties": {
        "passed": { "type": "boolean" },
        "gates": { "type": "array", "items": { "$ref": "safety.json" } }
      }
    },
    "executed_at": { "type": "string", "format": "date-time" },
    "result": { "type": "object" },
    "error": { "type": ["string", "null"] },
    "duration_ms": { "type": "integer" }
  }
}
